{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-client/main/tauri-client/src/capability.json",
  "identifier": "default",
  "description": "Default capabilities for SaraaTEK",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "shell:allow-open",
    "dialog:default",
    "store:default"
  ]
}
